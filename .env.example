# Solstice — Local environment example
# Copy to .env.local and fill in real values.
# Never commit .env.local.

# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://solstice:solstice@localhost:5432/solstice_dev

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Game server ──────────────────────────────────────────────
GAME_SERVER_PORT=4000
GAME_SERVER_HOST=0.0.0.0

# ─── Web app ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ─── Auth ─────────────────────────────────────────────────────
SESSION_SECRET=replace-me-with-32-bytes-of-random-hex
ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# ─── Crypto provider (sandbox keys only in dev) ───────────────
# Pick one: NOWPayments OR CoinsPaid. Final selection at integration.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
COINSPAID_API_KEY=
COINSPAID_API_SECRET=

# ─── KYC ──────────────────────────────────────────────────────
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=

# ─── Bot protection ───────────────────────────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Observability ────────────────────────────────────────────
SENTRY_DSN=
GRAFANA_LOKI_URL=

# ─── Geo ──────────────────────────────────────────────────────
MAXMIND_LICENSE_KEY=
MAXMIND_DB_PATH=./data/GeoLite2-Country.mmdb

# ─── Feature flags ────────────────────────────────────────────
FEATURE_REGISTRATION_ENABLED=true
FEATURE_DEPOSITS_ENABLED=true
FEATURE_WITHDRAWALS_ENABLED=true
